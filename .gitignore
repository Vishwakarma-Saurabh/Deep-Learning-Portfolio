.ipynb_checkpoints/
*.ipynb

# Docker
docker-compose.override.yml

# Streamlit
.streamlit/

# Test artifacts
data/
test_contract*.pdf
tmp*

# Monitoring database
*.db
*.sqlite

# Python type checking
.mypy_cache/
.pyre/

